# ─────────────────────────────────────────────────────────────────────────────
# Curi — environment template. Copy to .env.local and fill in real values.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase (apps/web — public, anon key only)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (packages/ingestion — server only, NEVER expose to the browser)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# MusicBrainz — required User-Agent per their ToS
MUSICBRAINZ_USER_AGENT=Curi/0.1 (cmitsuo7@yahoo.com)

# Shotgun (used by ingestion)
SHOTGUN_BASE_URL=https://shotgun.live

# Ingestion runtime
INGEST_DEFAULT_SOURCES=all
INGEST_POLITE_DELAY_MS=1500
