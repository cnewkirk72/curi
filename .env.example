# ─────────────────────────────────────────────────────────────────────────────
# Curi — environment template. Copy to .env.local and fill in real values.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase (apps/web — public, anon key only)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (packages/ingestion — server only, NEVER expose to the browser)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# MusicBrainz — required User-Agent per their ToS (no default — must be set)
MUSICBRAINZ_USER_AGENT=Curi/0.1 (your-contact@example.com)

# Ingestion runtime
# INGEST_DEFAULT_SOURCES options:
#   all                                  — every registered scraper
#   ra-nyc                               — NYC-wide RA aggregator only
#   venue:public-records,venue:nowadays  — pick-list (comma-separated)
INGEST_DEFAULT_SOURCES=all
INGEST_POLITE_DELAY_MS=1500
# CURI_VERBOSE=1                         — extra logging (e.g. ra-nyc drop tally)

# Spotify Web API (optional — used for artist genre enrichment)
# Create an app at https://developer.spotify.com/dashboard, then copy the
# Client ID + Client Secret here. Uses Client Credentials flow (catalog reads
# only), so dev-mode's 25-user cap does NOT apply — no user auth needed.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# SoundCloud OAuth 2.1 (Phase 5.8 — user-auth connect on /profile).
# Register an app at https://soundcloud.com/you/apps/new to get the
# Client ID + Secret. The Redirect URI must EXACTLY match what's
# registered on the SC dashboard (scheme, host, path, no trailing slash).
# Cookie secret is used to HMAC-sign the short-lived OAuth-state cookie
# during the authorize → callback round trip; generate with
# `openssl rand -hex 32`.
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=
SOUNDCLOUD_REDIRECT_URI=http://localhost:3000/api/soundcloud/callback
SOUNDCLOUD_OAUTH_COOKIE_SECRET=
