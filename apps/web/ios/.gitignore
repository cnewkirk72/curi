# Capacitor iOS .gitignore — track source, ignore build artifacts.
#
# This file should be committed alongside the iOS scaffold so the
# Xcode project survives across machines and pulls. Phase 5.7.1
# recovery (2026-04-29) added this after a junk-cleanup script
# accidentally moved the entire ios/ directory into a backup folder
# and the project.pbxproj was lost — see roadmap follow-up
# "Track the iOS Capacitor scaffold in git".

# Build artifacts
build/
DerivedData/
.build/

# CocoaPods (if ever used; this project uses SPM but ignore for safety)
Pods/
Podfile.lock

# Xcode user state — per-developer, never share
xcuserdata/
*.xcuserstate
*.xcuserstate.xcuserdata

# macOS
.DS_Store

# Capacitor sync outputs that get regenerated by `npx cap sync`
# (Don't ignore App/public/ — that's the bundled web shim; it's
# small and stable. Don't ignore App/capacitor.config.json either —
# generated from the source apps/web/capacitor.config.ts but kept in
# tree so the iOS build is reproducible without running cap sync first.)
