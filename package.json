{
  "name": "curi",
  "version": "0.1.0",
  "private": true,
  "description": "NYC electronic music events discovery PWA.",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "pnpm --filter @curi/web dev",
    "build": "pnpm --filter @curi/web build",
    "start": "pnpm --filter @curi/web start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "ingest": "pnpm --filter @curi/ingestion ingest",
    "smoke:ticketmaster": "pnpm --filter @curi/ingestion smoke:ticketmaster"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
