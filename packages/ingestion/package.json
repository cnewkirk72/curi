{
  "name": "@curi/ingestion",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "curi-ingest": "./dist/cli.js"
  },
  "scripts": {
    "ingest": "tsx src/cli.ts",
    "smoke:ticketmaster": "tsx scripts/smoke-ticketmaster-nyc.ts",
    "smoke:sc-follows": "tsx scripts/test-soundcloud-follows.ts",
    "refresh:sc-follows": "tsx src/cli-sc-refresh.ts",
    "smoke:spotify-follows": "tsx scripts/test-spotify-follows.ts",
    "refresh:spotify-follows": "tsx src/cli-spotify-refresh.ts",
    "healthcheck:spotify-bot": "tsx scripts/healthcheck-spotify-bot.ts",
    "enrich": "tsx src/llm-enrichment-run.ts",
    "dry-run": "tsx src/llm-enrichment-dry-run.ts",
    "backfill": "tsx src/backfill-run.ts",
    "backfill-avatars": "tsx src/backfill-avatars.ts",
    "repair-sc-images": "tsx src/repair-sc-images.ts",
    "spotify-retry": "tsx src/spotify-retry.ts",
    "spotify-catchup": "tsx src/spotify-catchup.ts",
    "audit": "tsx src/audit.ts",
    "audit:cleanup": "tsx src/audit-cleanup.ts",
    "reaggregate": "tsx src/events-reaggregate.ts",
    "start": "node dist/cli.js",
    "build": "tsc -p tsconfig.json",
    "lint": "echo 'no-op — add eslint in phase 2'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.60.0",
    "@supabase/supabase-js": "^2.45.4",
    "playwright": "^1.48.1",
    "zod": "^3.23.8",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
