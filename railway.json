{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "node packages/ingestion/dist/cli.js",
    "numReplicas": 1,
    "sleepApplication": false,
    "restartPolicyType": "NEVER",
    "cronSchedule": "0 10 * * *"
  }
}
