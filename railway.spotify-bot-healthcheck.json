{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "pnpm --filter @curi/ingestion healthcheck:spotify-bot",
    "numReplicas": 1,
    "sleepApplication": false,
    "restartPolicyType": "NEVER",
    "cronSchedule": "0 9 * * *"
  }
}
